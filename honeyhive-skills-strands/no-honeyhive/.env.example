# Required for agent + eval
OPENAI_API_KEY=
# Optional — defaults to gpt-5-mini (agent + judge)
OPENAI_MODEL=gpt-5-mini

# HoneyHive — needed from Step 2 onward
# https://app.honeyhive.ai/settings/project/keys
HH_API_KEY=
HH_PROJECT=Strands
# Dedicated / self-host only — omit to use the multi-tenant default
HH_API_URL=
