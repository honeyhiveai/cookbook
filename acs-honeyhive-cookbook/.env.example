# HoneyHive
HH_API_KEY=your-honeyhive-api-key
# Optional: override the HoneyHive API URL if you are not on the default region.
# HH_API_URL=https://api.dp1.us.prod.honeyhive.ai
# Optional: project for the verification query (the backend infers scope from the key).
# HH_PROJECT=Your Project

# OpenAI (required for bank_agent_live.py; optional for the other runners)
OPENAI_API_KEY=your-openai-api-key
# OPENAI_MODEL=gpt-4o   # bank_agent_live.py default; bank_agent_runner.py defaults to gpt-4o-mini

# ACS needs the OPA binary on PATH for Rego policies. Point this at the binary.
# See scripts/setup_opa.sh.
ACS_OPA_PATH=/absolute/path/to/opa
