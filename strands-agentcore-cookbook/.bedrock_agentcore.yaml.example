# Bedrock AgentCore deployment config — TEMPLATE.
#
# This file is normally generated by `agentcore configure -e agent.py`. The
# real `.bedrock_agentcore.yaml` is gitignored because it contains
# account-specific values (account ID, ECR URI, IAM role ARN). Copy this
# template to `.bedrock_agentcore.yaml` and fill in the placeholders, OR run
# `agentcore configure -e agent.py` and let the CLI generate it for you.
#
# The model is NOT configured here — it lives in agent.py via
# BedrockModel(model_id=...). To swap to an application-inference-profile
# ARN (e.g. for per-tenant cost tracking), set BEDROCK_MODEL_ID in the
# runtime environment instead of editing this file.

default_agent: strands_agentcore_demo

agents:
  strands_agentcore_demo:
    name: strands_agentcore_demo
    entrypoint: agent.py

    platform: linux/arm64
    container_runtime: docker

    aws:
      account: 'YOUR_AWS_ACCOUNT_ID'
      region: us-east-1
      execution_role: arn:aws:iam::YOUR_AWS_ACCOUNT_ID:role/BedrockAgentCoreRuntime
      ecr_repository: YOUR_AWS_ACCOUNT_ID.dkr.ecr.us-east-1.amazonaws.com/strands-agentcore-demo
      ecr_auto_create: true
      network_configuration:
        network_mode: PUBLIC
      protocol_configuration:
        server_protocol: HTTP
      observability:
        enabled: true

    bedrock_agentcore:
      agent_id: null
      agent_arn: null
      agent_session_id: null

    authorizer_configuration: null
    oauth_configuration: null
